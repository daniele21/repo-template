{
  "name": "repo-template",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.21.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node apps/api/src/server.ts",
    "dev:watch": "node --watch-path=apps/api/src --watch-path=packages apps/api/src/server.ts",
    "lint": "node ./scripts/lint.mjs",
    "typecheck": "node ./scripts/typecheck.mjs",
    "test": "node --test",
    "build": "node ./scripts/build.mjs",
    "docs:check": "node ./scripts/docs-check.mjs",
    "ui:check-system": "node ./scripts/check-design-system.mjs",
    "security:check": "node ./scripts/security-check.mjs",
    "deps:audit": "node ./scripts/dependency-audit.mjs",
    "verify": "pnpm run lint && pnpm run typecheck && pnpm run ui:check-system && pnpm run test && pnpm run build",
    "verify:full": "pnpm run verify && pnpm run docs:check && pnpm run security:check && pnpm run deps:audit"
  }
}
